<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.NexusBridge" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <!-- Numpad button style -->
    <style name="NumpadButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:backgroundTint">@color/surface2</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
